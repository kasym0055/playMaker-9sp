<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/min_padding"
    android:gravity="center_vertical"
    >
    <ImageView
        android:id="@+id/music_picture"
        android:layout_width="@dimen/picture_size_music"
        android:layout_height="@dimen/picture_size_music"
        android:layout_marginStart="@dimen/margin5"
        android:src="@drawable/img_1"/>

    <LinearLayout
        android:layout_width="@dimen/zero"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingStart="@dimen/min_padding"
        android:paddingEnd="@dimen/min_padding"
        android:orientation="vertical">
        <TextView
            android:id="@+id/name_music"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="@dimen/name_music"
            android:textColor="@color/yp_color_text"
            android:fontFamily="@font/ys_display_regular"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/author_music"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="@dimen/author_name_music"
                android:textColor="@color/author_name_color_music"
                android:fontFamily="@font/ys_display_regular"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dot"/>
            <TextView
                android:id="@+id/time_music"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="@dimen/author_name_music"
                android:textColor="@color/author_name_color_music"
                android:fontFamily="@font/ys_display_regular"/>
        </LinearLayout>

    </LinearLayout>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/arrow_forward"
        android:padding="@dimen/min_padding"
        />

</LinearLayout>
